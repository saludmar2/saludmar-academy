rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }

    function isValidParticipant(incoming) {
      return incoming.id is string
        && incoming.nombre is string
        && incoming.cedula is string
        && incoming.correo is string
        && incoming.cursoId is string;
    }

    // Courses collection rules
    match /courses/{courseId} {
      allow read: if true; // anyone can fetch courses for info or enrollment
      allow write: if true; // admin updates course info (video links, bibliography, infographies, and exams)
    }

    // Participants collection rules
    match /participants/{participantId} {
      allow read: if true; // anyone can lookup a code or display a certificate
      allow create: if isValidId(participantId) && isValidParticipant(request.resource.data);
      allow update, delete: if true; // admin operations or status edits
    }

    // Signatures collection rules
    match /signatures/{signatureId} {
      allow read: if true; // anyone can view a signature on a certificate
      allow write: if true; // admin updates available signatures
    }

    // Layout configuration rules
    match /layout/{document} {
      allow read: if true; // anyone can view Layout configuration to adjust frame styling
      allow write: if true; // admin updates Layout styling configuration
    }

    // System collection rules
    match /system/{document} {
      allow read, write: if true;
    }
  }
}
